[resource]
script = ExtResource("1_cp0h7")
plant_id = "death_cap"
display_name = "Death Cap"
visual_clue = "Pale yellow-green cap, 5-15cm wide. White gills and white stem with a ring. Base has a cup-like volva. Smells faintly sweet when young."
real_world_fact = "Responsible for 90% of fatal mushroom poisonings worldwide. Symptoms appear 6-24 hours after eating. Has no antidote — even a small piece can be lethal."
image = ExtResource("1_j0rce")
