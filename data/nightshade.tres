[resource]
script = ExtResource("1_rl4gk")
plant_id = "nightshade"
display_name = "Nightshade"
visual_clue = "Shiny black berries in small clusters, green when unripe. Small purple star-shaped flowers with yellow stamens. Oval pointed leaves. Plant 30-120cm tall."
real_world_fact = "Contains solanine and other toxic alkaloids. Even a few berries can cause severe poisoning in children. Related to tomatoes and potatoes but far more toxic."
image = ExtResource("1_glkkp")
