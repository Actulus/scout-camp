[resource]
script = ExtResource("1_sbf4r")
plant_id = "fly_agaric"
display_name = "Fly Agaric"
visual_clue = "Bright red or orange-red cap with distinctive white spots. White gills, white stem with a ring and bulbous base. Cap 8-20cm wide. Iconic toadstool appearance."
real_world_fact = "Contains muscimol and ibotenic acid causing hallucinations and delirium. Rarely fatal but severely toxic. The white spots can wash off in rain making identification harder."
image = ExtResource("1_d0kl1")
