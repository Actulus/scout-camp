[resource]
script = ExtResource("1_0n6s5")
plant_id = "elderberry"
display_name = "Elderberry"
is_safe = true
visual_clue = "Small dark purple-black berries in large flat-topped clusters. Compound leaves with 5-7 leaflets. Shrub or small tree up to 6m. Berries droop when ripe."
real_world_fact = "Raw berries contain cyanogenic glycosides and can cause nausea. Must be cooked before eating. Widely used for elderberry syrup, wine and immune support remedies."
image = ExtResource("1_0beje")
