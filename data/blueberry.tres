plant_id = "blueberry"
display_name = "Blueberry"
is_safe = true
visual_clue = "Small round blue-purple berries in clusters. Oval leaves with fine teeth. Low shrub 20-50cm tall. Berries have a small crown at the tip."
real_world_fact = "One of the most nutritious wild berries. High in antioxidants and vitamin C. Found in acidic forest soils. Can be eaten raw or used to make jam and tea."
