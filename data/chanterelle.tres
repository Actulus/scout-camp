[resource]
script = ExtResource("1_ngnlx")
plant_id = "chanterelle"
display_name = "Chanterelle"
is_safe = true
visual_clue = "Golden-yellow egg-yolk colored cap, wavy edges, 3-10cm wide. Forked ridges underneath instead of true gills. Fruity apricot smell. Solid white stem."
real_world_fact = "One of the most prized edible wild mushrooms in the world. Found near oak and pine trees in summer and autumn. Rich in vitamin D and iron. Used in fine cuisine across Europe."
