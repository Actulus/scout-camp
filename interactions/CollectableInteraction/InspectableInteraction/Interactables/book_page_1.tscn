content = "[b]Lost Scout Notes - Page 1 of 3[/b]\\n\\nDear fellow scouts,\\n\\nI lost my navigation notes across camp while hiking. If you find this, please collect the other two pages!\\n\\nUse your [b]map and compass[/b] (press M) to help you search. Red markers show page locations.\\n\\nPage 2 clue: Walk [b]northeast[/b] from the firepit. Look among the tall pine trees.\\n\\nPage 3 clue: Head [b]southwest[/b] from camp toward the river bend.\\n\\nGood luck, scout!\\n- Kofi"
collect_sound_effect = ExtResource("3_p3g4h")
