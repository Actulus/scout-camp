[node name="InspectableInteraction" parent="." unique_id=300000004 instance=ExtResource("2_a4uc4")]
content = "[center][b]Survival Notes[/b][/center]\n\nFire tip: collect wood before dark, never after. Wet wood smokes but won't light.\n\nThe chanterelles near the big oak are safe — confirmed with the field guide. Stay away from anything with white gills and a ring on the stem.\n\nCompass always points me back to camp from the ridge. The lake is a good landmark.\n\n[color=#8B4513][i]Mark your trail. The forest looks the same in every direction once you go deep enough.[/i][/color]"
collect_sound_effect = ExtResource("3_p3g4h")
item_data = SubResource("Resource_bp2data")
